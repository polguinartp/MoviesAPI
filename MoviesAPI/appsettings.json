  "Serilog": {
    "Using": ["Serilog.Sinks.Debug"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Debug"
      }
      //{
      //  "Name": "File",
      //  "Args": {
      //    "path": "C:\\Logs\\log.txt",
      //    "outputTemplate": "{Timestamp} {Message}{NewLine:1}{Exception:1}"
      //  }
      //}
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithProcessId",
      "WithThreadId"
    ]
  },
  "AllowedHosts": "*",
  "IMDBWebApiClient": {
    "Url": "",
    "ApiKey": "",
    "StatusTimestamp": 60
  },
  "SQS": {
    "AwsAccessKey": "",
    "AwsSecretKey": "",
    "Region": "us-east-1",
    "QueueUrl": "https://sqs.us-east-1.amazonaws.com/874389983356/MyMessages.fifo"
  },
  // In real scenario it should be stored as secret in AWS Secrets Manager
  "AuthenticationKey" : "MOVIES_API_AUTHENTICATION_KEY_123456"
